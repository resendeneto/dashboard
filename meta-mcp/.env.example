# ─────────────────────────────────────────────────────
# Meta Social MCP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────

# Token de acesso de longa duração da Meta (User ou System User)
# Gere em: https://developers.facebook.com/tools/explorer/
# Permissões necessárias:
#   instagram_basic, instagram_manage_insights,
#   ads_read, ads_management, read_insights
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxx

# ID numérico da conta Instagram Business
# Encontre em: Meta Business Suite → Configurações → Contas do Instagram
# Ou via API: GET /me/accounts → pegar page_id → GET /{page_id}?fields=instagram_business_account
META_IG_ACCOUNT_ID=17841400000000000

# ID da conta de anúncios (somente números, sem "act_")
# Encontre em: Meta Ads Manager → URL do navegador: act_XXXXXXXXXXX
META_AD_ACCOUNT_ID=123456789

# Caminho completo para a pasta do Dashboard Social
# O arquivo de backup será salvo aqui para importação fácil
DASHBOARD_PATH=C:\Users\PedroHenriqueFerreir\OneDrive - Grupo BS Tecnologia\Área de Trabalho\Vscode\dashboard-social

# ─────────────────────────────────────────────
# GitHub + Vercel MCP — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ─────────────────────────────────────────────

# Token pessoal do GitHub com escopo "repo"
# Gere em: github.com/settings/tokens → New classic token → marque "repo"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Seu usuário do GitHub
GITHUB_USERNAME=seu-usuario

# Nome do repositório (será criado automaticamente)
GITHUB_REPO_NAME=dashboard-social

# Caminho para a pasta do dashboard
DASHBOARD_PATH=C:\Users\PedroHenriqueFerreir\OneDrive - Grupo BS Tecnologia\Área de Trabalho\Vscode\dashboard-social

# Token do Vercel (opcional — se não definido, usa npx vercel com login)
# Gere em: vercel.com/account/tokens
VERCEL_TOKEN=
